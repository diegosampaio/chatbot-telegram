      "position": [
        -448,
        112
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.cod }}",
              "operation": "equal",
              "value2": 200
            }
          ]
        }
      },
      "id": "8b2c7422-da34-4a65-aa24-18f479ef8753",
      "name": "Validar Resposta",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -224,
        112
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $node[\"Telegram Trigger\"].json.message.chat.id }}",
