          "id": "pKPD0inbjkBOJ1aP",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const temp = Math.round($node[\"OpenWeather API\"].json.main.temp);\nconst city = $node[\"OpenWeather API\"].json.name;\n\nreturn {\n  message: `🌤️ A temperatura em ${city} é de ${temp}°C.`,\n  ok: true\n};"
      },
      "id": "93ee9412-f9d0-46bd-8da6-80fb81aa866c",
